{
  "name": "@gpuix/native",
  "version": "0.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "gpuix-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --features test-support",
    "build:release": "napi build --platform --release",
    "build:debug": "napi build --platform --features test-support",
    "prepublishOnly": "napi pre-publish -t npm",
    "universal": "napi universal",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.1.3"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
